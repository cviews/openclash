{
  "name": "@openplaw/openclash",
  "version": "0.1.3",
  "description": "ACP to OpenAI protocol conversion gateway - expose ACP agents as OpenAI-compatible API endpoints",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "openclash": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/cli/index.ts start",
    "start": "node dist/cli/index.js start",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@hono/node-server": "^1.13.0",
    "@opencode-ai/plugin": "^1.14.48",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "acp",
    "openai",
    "gateway",
    "protocol",
    "agent",
    "opencode"
  ],
  "license": "MIT"
}
